# Supabase (copy to .env and fill in)
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# RevenueCat (from dashboard → API keys)
EXPO_PUBLIC_REVENUECAT_IOS_API_KEY=appl_xxxx
EXPO_PUBLIC_REVENUECAT_ANDROID_API_KEY=goog_xxxx

# Optional: Test Store key for dev (RevenueCat → Apps and providers → Test configuration → Create Test Store).
# When set and running in __DEV__, SDK uses Test Store (modal success/fail/cancel) instead of real store.
# Never use this key in production builds.
# EXPO_PUBLIC_REVENUECAT_TEST_STORE_API_KEY=rcb_xxxx
